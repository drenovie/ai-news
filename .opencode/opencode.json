{
  "name": "ai-news",
  "version": "1.0.0",
  "nodeVersion": "20",
  "workspaceRoot": ".",
  "commands": {
    "dev": {
      "command": "npm",
      "args": ["run", "dev"],
      "description": "Start development server (Vite)"
    },
    "build": {
      "command": "npm",
      "args": ["run", "build"],
      "description": "Build for production (Cloudflare Pages)"
    },
    "preview": {
      "command": "npm",
      "args": ["run", "preview"],
      "description": "Preview production build"
    },
    "install": {
      "command": "npm",
      "args": ["install"],
      "description": "Install dependencies"
    }
  },
  "mcpServers": {
    "supabase": {
      "type": "remote",
      "url": "https://mcp.supabase.com/mcp?project_ref=btebbnwvdxishilssfnw",
      "enabled": true
    }
  }
}
